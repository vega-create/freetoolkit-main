        <tr style="background: #f8fafc;"><td style="padding: 10px; border: 1px solid #e2e8f0;">Studying at a Taiwanese university</td><td style="padding: 10px; border: 1px solid #e2e8f0; text-align: center; font-weight: bold; color: #ca8a04;">Bopomofo</td><td style="padding: 10px; border: 1px solid #e2e8f0;">Language courses in Taiwan teach Zhuyin</td></tr>
