import BlogLayout from '../../../layouts/BlogLayout.astro';
const faq = [
  { q: `What are the most important Chinese conjunctions to learn first?`, a: `Start with the four essential paired connectors: 因为...所以 (because...so), 虽然...但是 (although...but), 如果...就 (if...then), and 不但...而且 (not only...but also). These cover the majority of complex sentences in daily conversation.` },
  { q: `Why do Chinese conjunctions come in pairs?`, a: `Chinese grammar favors balanced structures. Paired connectors clearly mark both halves of a complex sentence, making the logical relationship explicit. In casual speech, native speakers often drop one half of the pair (usually the first), but learners should practice using both for clarity.` },
  { q: `Can I use only one half of a connector pair?`, a: `Yes, in many cases. For 因为...所以, you can drop either half: 因为下雨我不去 or 下雨所以我不去. For 虽然...但是, dropping 虽然 is common in casual speech. However, 如果...就 almost always keeps 就 even if 如果 is dropped.` },
  { q: `What is the difference between 但是, 可是, and 不过?`, a: `All three mean "but/however." 但是 (dànshì) is the most common and neutral. 可是 (kěshì) is slightly more colloquial and emotional. 不过 (búguò) is the softest, meaning "however" or "it's just that." In formal writing, 但是 or 然而 (rán'ér) are preferred.` },
  { q: `How many connectors do I need for HSK?`, a: `HSK 1-2 requires basic connectors like 和, 但是, 因为. HSK 3-4 adds paired connectors like 虽然...但是, 如果...就, 不但...而且. HSK 5-6 introduces formal and literary connectors like 尽管, 即使, 与其...不如. This guide covers all levels.` }
];
