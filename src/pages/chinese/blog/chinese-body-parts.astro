  <tbody>
    <tr style="background:#fef2f2;"><td style="padding:8px; border:1px solid #e2e8f0; width:40%;">头疼 (tóu téng)</td><td style="padding:8px; border:1px solid #e2e8f0;">headache</td></tr>
    <tr><td style="padding:8px; border:1px solid #e2e8f0;">牙疼 (yá téng)</td><td style="padding:8px; border:1px solid #e2e8f0;">toothache</td></tr>
