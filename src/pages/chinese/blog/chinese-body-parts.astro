    <tr><td style="padding:8px; border:1px solid #e2e8f0;">嘴巴</td><td style="padding:8px; border:1px solid #e2e8f0;">zuǐba</td><td style="padding:8px; border:1px solid #e2e8f0;">mouth</td><td style="padding:8px; border:1px solid #e2e8f0;">口 radical = mouth</td></tr>
