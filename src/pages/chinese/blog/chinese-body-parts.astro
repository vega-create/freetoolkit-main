<BlogLayout
  title="Chinese Body Parts Vocabulary: 60+ Essential Words for Health and Daily Life"
  description="Master 60+ Chinese body part words with pinyin, radicals, health phrases, and cultural idioms. Essential for doctor visits, sports, and everyday conversation."
  language="chinese"
  category="chinese-basics"
  tags={["body", "vocabulary", "beginner", "health", "radicals"]}
  publishDate="2026-02-27"
  updatedDate="2026-03-19"
  image="https://images.pexels.com/photos/7723385/pexels-photo-7723385.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940"
