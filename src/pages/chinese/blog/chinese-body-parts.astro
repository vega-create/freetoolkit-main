    <tr style="background:#f8fafc;"><td style="padding:8px; border:1px solid #e2e8f0;">头发</td><td style="padding:8px; border:1px solid #e2e8f0;">tóufa</td><td style="padding:8px; border:1px solid #e2e8f0;">hair</td><td style="padding:8px; border:1px solid #e2e8f0;">头 (head) + 发 (emit/grow)</td></tr>
    <tr><td style="padding:8px; border:1px solid #e2e8f0;">脸</td><td style="padding:8px; border:1px solid #e2e8f0;">liǎn</td><td style="padding:8px; border:1px solid #e2e8f0;">face</td><td style="padding:8px; border:1px solid #e2e8f0;">月 radical = flesh</td></tr>
    <tr style="background:#f8fafc;"><td style="padding:8px; border:1px solid #e2e8f0;">额头</td><td style="padding:8px; border:1px solid #e2e8f0;">étóu</td><td style="padding:8px; border:1px solid #e2e8f0;">forehead</td><td style="padding:8px; border:1px solid #e2e8f0;">额 = the upper part of face</td></tr>
    <tr><td style="padding:8px; border:1px solid #e2e8f0;">眼睛</td><td style="padding:8px; border:1px solid #e2e8f0;">yǎnjing</td><td style="padding:8px; border:1px solid #e2e8f0;">eyes</td><td style="padding:8px; border:1px solid #e2e8f0;">目 radical = eye</td></tr>
    <tr style="background:#f8fafc;"><td style="padding:8px; border:1px solid #e2e8f0;">眉毛</td><td style="padding:8px; border:1px solid #e2e8f0;">méimao</td><td style="padding:8px; border:1px solid #e2e8f0;">eyebrows</td><td style="padding:8px; border:1px solid #e2e8f0;">眉 looks like brows over an eye</td></tr>
