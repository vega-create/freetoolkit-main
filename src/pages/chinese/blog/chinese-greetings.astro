        <div style="display: flex; align-items: center; gap: 0.5rem;"><span style="width: 80px; font-size: 0.75rem; text-align: right; color: #374151;">吃了吗</span><div style="flex: 1; background: #e5e7eb; border-radius: 4px; height: 22px;"><div style="background: #2563eb; height: 100%; border-radius: 4px; width: 25%; display: flex; align-items: center; padding-left: 6px; color: #fff; font-size: 0.7rem; font-weight: 600;">25%</div></div></div>
