<BlogLayout
  title="Chinese Particles Explained: 了 过 着 的 地 得 吗 吧 呢"
  description="Master the most confusing aspect of Chinese grammar. Clear explanations of every major particle with example sentences, comparison charts, and common mistakes to avoid."
  language="chinese"
  category="grammar"
  tags={["grammar", "particles", "intermediate", "le", "de"]}
  publishDate="2026-02-25"
  image="https://images.pexels.com/photos/5303510/pexels-photo-5303510.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940"
