    <tr><td style="padding:8px; border:1px solid #e2e8f0;">毕业</td><td style="padding:8px; border:1px solid #e2e8f0;">bìyè</td><td style="padding:8px; border:1px solid #e2e8f0;">graduate</td></tr>
