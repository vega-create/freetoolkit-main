---
import BlogLayout from '../../../layouts/BlogLayout.astro';
const faq = [
  {"q": "When is Chinese New Year?", "a": "Chinese New Year follows the lunar calendar, so the date changes each year, falling between January 21 and February 20. The celebration lasts 15 days, starting with New Year's Eve (除夕) and ending with the Lantern Festival (元宵节) on the 15th day of the first lunar month."},
  {"q": "What is the most important tradition of Chinese New Year?", "a": "The reunion dinner (团圆饭) on New Year's Eve is considered the most important tradition. Family members travel from across the country to gather for this meal — it is the largest annual human migration in the world, known as 春运 (chūnyùn)."},
  {"q": "Why is everything red during Chinese New Year?", "a": "Red (红色) symbolizes luck, prosperity, and happiness in Chinese culture. According to legend, the color red scared away the monster Nian (年). Red decorations, red envelopes, red clothing, and red lanterns are all meant to bring good fortune."},
  {"q": "How much money should go in a red envelope?", "a": "The amount varies by relationship and region. In mainland China, 200-1000 RMB per envelope is common for relatives. In Taiwan, amounts often contain 6 or 8 (lucky numbers). Always use new, crisp bills and even amounts — odd numbers are associated with funerals."},
  {"q": "What foods are traditionally eaten for Chinese New Year?", "a": "Dumplings (饺子) in northern China symbolize wealth (they look like ancient gold ingots). Fish (鱼) symbolizes surplus (余, yú sounds the same). Spring rolls (春卷) represent wealth. Sticky rice cake (年糕) symbolizes rising higher each year. Tangyuan (汤圆) represent family reunion."}
];
const relatedTools = [
  {"name": "Name Generator", "url": "/chinese/tools/name-generator/"},
  {"name": "Character Counter", "url": "/chinese/tools/character-counter/"}
];
const headings = [
  {"depth": 2, "slug": "overview", "text": "What Is Chinese New Year?"},
  {"depth": 2, "slug": "preparations", "text": "Pre-New Year Preparations"},
  {"depth": 2, "slug": "new-years-eve", "text": "New Year's Eve (除夕)"},
  {"depth": 2, "slug": "traditions", "text": "Key Traditions Day by Day"},
  {"depth": 2, "slug": "food", "text": "Traditional New Year Foods"},
  {"depth": 2, "slug": "vocabulary", "text": "Essential Vocabulary (40+ Words)"},
  {"depth": 2, "slug": "greetings", "text": "New Year Greetings"},
  {"depth": 2, "slug": "taboos", "text": "Things to Avoid During New Year"}
];
---
<BlogLayout
  title="Chinese New Year: Complete Guide to Traditions, Food, and Vocabulary"
  description="Everything about Chinese New Year — traditions day by day, symbolic foods, 40+ essential vocabulary words, greetings, red envelope etiquette, and cultural taboos."
  language="chinese"
  category="culture"
  tags={["chinese-new-year", "culture", "traditions", "vocabulary"]}
  publishDate="2026-02-26"
  image="https://images.pexels.com/photos/36199306/pexels-photo-36199306.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940"
  imageAlt="A stunning aerial view of a vibrant red lantern display for Lunar New Year celebrations."
  faq={faq}
  relatedTools={relatedTools}
