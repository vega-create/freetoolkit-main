---
import BlogLayout from '../../../layouts/BlogLayout.astro';

const faq = [
  { q: `Is bargaining common in China?`, a: `Bargaining is expected in street markets, small shops, and tourist areas — starting at 50-60% of the asking price is standard. However, fixed-price stores (malls, chain stores, supermarkets) and Taiwan's shops generally do not negotiate. Night markets in Taiwan sometimes allow mild bargaining for bulk purchases.` },
  { q: `How does mobile payment work in China?`, a: `WeChat Pay (微信支付) and Alipay (支付宝) dominate payments in mainland China. You scan QR codes to pay at almost any business, from restaurants to street vendors. As a tourist, setting up these apps can be tricky — carry some cash as backup, especially for small purchases. Taiwan primarily uses cash and credit cards, with LINE Pay growing in popularity.` },
  { q: `What are the best shopping phrases for tourists?`, a: `Start with 多少钱？(how much?), 太贵了 (too expensive), 可以便宜一点吗？(can you make it cheaper?), and 我要这个 (I want this one). These four phrases cover most tourist shopping situations. Also learn 可以试穿吗？(can I try it on?) for clothing.` },
  { q: `How do I understand Chinese clothing sizes?`, a: `China uses its own sizing system. S/M/L/XL labels are common for international brands, but local sizes often use numbers like 160/80A or 165/84A. The first number is height in cm, the second is chest/waist measurement. When shopping, 试穿 (try on) is always the safest approach.` },
];

const relatedTools = [
  { name: "Number Converter", url: "/chinese/tools/number-converter/" },
  { name: "Pinyin Converter", url: "/chinese/tools/pinyin-converter/" },
  { name: "HSK Vocabulary Browser", url: "/chinese/tools/hsk-vocabulary/" },
];

const headings = [
  { depth: 2, slug: "basic-phrases", text: "Basic Shopping Phrases" },
  { depth: 2, slug: "pricing-numbers", text: "Pricing and Numbers" },
  { depth: 2, slug: "bargaining", text: "Bargaining Like a Local" },
  { depth: 2, slug: "clothing", text: "Clothing and Accessories" },
  { depth: 2, slug: "grocery", text: "Grocery and Market Shopping" },
  { depth: 2, slug: "payment", text: "Payment Methods" },
  { depth: 2, slug: "returns", text: "Returns, Exchanges, and Problems" },
  { depth: 2, slug: "shopping-types", text: "Types of Stores and Markets" },
];
