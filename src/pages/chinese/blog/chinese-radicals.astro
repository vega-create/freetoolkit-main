        <tr style="background:#eff6ff"><td style="padding:8px 14px;text-align:center">19</td><td style="padding:8px 14px">犭(犬 quǎn)</td><td style="padding:8px 14px">Animal</td><td style="padding:8px 14px">猫 cat · 狗 dog · 猪 pig · 狼 wolf</td></tr>
