        <td style="padding: 10px;">Pleased to meet you</td>
        <td style="padding: 10px;">First meeting (formal)</td>
      </tr>
      <tr style="background: #f8fafc; border-bottom: 1px solid #e2e8f0;">
        <td style="padding: 10px; font-weight: 600;">请多关照</td>
        <td style="padding: 10px;">qǐng duō guānzhào</td>
        <td style="padding: 10px;">Please take care of me / guide me</td>
        <td style="padding: 10px;">After self-introduction (shows humility)</td>
      </tr>
