---
import BaseLayout from '../layouts/BaseLayout.astro';
import SystemDashboard from '../components/SystemDashboard.tsx';
---

<BaseLayout
  title="System Dashboard | FreeToolkit"
  description="Central dashboard for all FreeToolkit systems, tools, and resources."
  noindex={true}
>
  {/* Header */}
  <section class="bg-gradient-to-br from-gray-900 to-gray-800 py-12 md:py-16">
    <div class="max-w-6xl mx-auto px-4">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-2">System Dashboard</h1>
      <p class="text-gray-400">所有系統與工具的快速入口，可自行新增、編輯、刪除</p>
    </div>
  </section>

  {/* Dashboard */}
  <section class="max-w-6xl mx-auto px-4 py-10">
    <SystemDashboard client:load />
  </section>
</BaseLayout>
