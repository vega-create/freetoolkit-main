    <tr style="background:#f8fafc;"><td style="padding:8px; border:1px solid #e2e8f0;">ピカピカ</td><td style="padding:8px; border:1px solid #e2e8f0;">pika pika</td><td style="padding:8px; border:1px solid #e2e8f0;">Shiny, sparkling</td><td style="padding:8px; border:1px solid #e2e8f0;">床がピカピカ (floor is sparkling clean)</td></tr>
    <tr><td style="padding:8px; border:1px solid #e2e8f0;">キラキラ</td><td style="padding:8px; border:1px solid #e2e8f0;">kira kira</td><td style="padding:8px; border:1px solid #e2e8f0;">Glittering, twinkling</td><td style="padding:8px; border:1px solid #e2e8f0;">星がキラキラ (stars twinkling)</td></tr>
    <tr style="background:#f8fafc;"><td style="padding:8px; border:1px solid #e2e8f0;">ネバネバ</td><td style="padding:8px; border:1px solid #e2e8f0;">neba neba</td><td style="padding:8px; border:1px solid #e2e8f0;">Sticky, slimy</td><td style="padding:8px; border:1px solid #e2e8f0;">納豆はネバネバしている</td></tr>
