    <tr style="background:#f8fafc;"><td style="padding:8px; border:1px solid #e2e8f0;">もちもち</td><td style="padding:8px; border:1px solid #e2e8f0;">mochi mochi</td><td style="padding:8px; border:1px solid #e2e8f0;">Chewy, springy</td><td style="padding:8px; border:1px solid #e2e8f0;">もちもちの食感 (chewy texture)</td></tr>
