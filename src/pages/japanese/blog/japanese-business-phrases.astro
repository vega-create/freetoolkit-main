];
---
<BlogLayout
  title="Essential Japanese Business Phrases for Email and Meetings"
  description="Master 80+ Japanese business phrases for email, meetings, phone calls, business card exchange, and professional self-introduction with keigo examples."
  language="japanese"
  category="culture"
  tags={["keigo", "vocabulary", "business", "intermediate"]}
  publishDate="2026-02-28"
  image="https://images.pexels.com/photos/7644152/pexels-photo-7644152.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940"
  imageAlt="A group of professionals discussing at a wooden table in an office meeting room."
  faq={faq}
  relatedTools={relatedTools}
