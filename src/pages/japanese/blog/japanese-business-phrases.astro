---
import BlogLayout from '../../../layouts/BlogLayout.astro';
const faq = [
  {"q": "Do I need keigo for business Japanese?", "a": "Yes. Business Japanese requires polite language (teineigo) at minimum, and formal keigo (sonkeigo and kenjougo) for client-facing communication, presentations, and emails. Even casual workplaces expect です/ます form with managers and external contacts."},
  {"q": "How do Japanese business emails differ from English?", "a": "Japanese business emails follow a strict structure: seasonal greeting (時候の挨拶), self-identification with company name, a humble opening phrase like お忙しいところ恐れ入りますが, the main content, a closing request phrase, and a formal signature block. They are significantly more formulaic than English emails."},
  {"q": "What is meishi koukan?", "a": "Business card exchange (名刺交換) is a formal ritual in Japan. You present your card with both hands facing the recipient, receive theirs with both hands while reading it, place it on the table during the meeting, and never write on someone's card. Forgetting your cards is considered very unprofessional."},
  {"q": "How formal should I be with Japanese coworkers?", "a": "Use です/ます form with anyone senior or from another department. With close colleagues at the same level, casual speech may develop over time, but always start formal. With clients or external contacts, full keigo is expected regardless of relationship."},
  {"q": "Can I use English in Japanese business settings?", "a": "It depends on the company. International firms may mix English and Japanese, but domestic companies expect Japanese communication. Even in English-friendly companies, internal emails and meetings with Japanese clients are conducted in Japanese with proper keigo."}
];
const relatedTools = [
  {"name": "JLPT Vocabulary", "url": "/japanese/tools/jlpt-vocabulary/"},
  {"name": "Daily Phrase", "url": "/japanese/tools/daily-phrase/"}
];
const headings = [
  {"depth": 2, "slug": "why-business-japanese", "text": "Why Business Japanese Matters"},
  {"depth": 2, "slug": "greetings", "text": "Essential Business Greetings"},
  {"depth": 2, "slug": "self-intro", "text": "Business Self-Introduction (自己紹介)"},
  {"depth": 2, "slug": "email", "text": "Email Phrases and Templates"},
  {"depth": 2, "slug": "meetings", "text": "Meeting Expressions"},
  {"depth": 2, "slug": "phone", "text": "Phone Etiquette Phrases"},
