  {"depth": 2, "slug": "mac", "text": "Mac Setup with Japanese IME"},
  {"depth": 2, "slug": "romaji-table", "text": "Romaji to Kana Conversion Table"},
  {"depth": 2, "slug": "mistakes", "text": "Common Typing Mistakes and How to Fix Them"},
