---
import BlogLayout from '../../../layouts/BlogLayout.astro';
const faq = [
  {
    "q": "What is romaji input vs kana input?",
    "a": "Romaji input lets you type using the English letters you already know — type 'ka' and the IME converts it to か, type 'shi' and you get し. Kana input requires learning a separate Japanese keyboard layout where each key corresponds directly to a kana. For beginners, romaji input is strongly recommended because there is nothing new to memorize for the physical keyboard. Advanced users sometimes prefer kana input for speed, but the difference is minor and romaji input is perfectly fine even at a professional level."
  },
  {
    "q": "How do I type kanji?",
    "a": "Type the reading of the word in hiragana using romaji input, then press the Space bar. A list of kanji candidates will appear — for example, typing 'nihon' gives you candidates including 日本, 二本, and others. Use the arrow keys or mouse to select the correct kanji, then press Enter to confirm. If you press Space again the candidate window expands to show more options. Over time the IME learns which words you use most often and prioritises them. For unfamiliar kanji, you can also use handwriting input on mobile devices to look them up by drawing the strokes."
  },
  {
    "q": "Can I handwrite Japanese on my phone?",
    "a": "Yes — both iOS and Android support handwriting input for Japanese. On iPhone, open Settings > General > Keyboard > Keyboards > Add New Keyboard, then select Japanese > Handwriting. On Android with Gboard, tap the keyboard icon and choose Handwriting. Handwriting input is especially useful when you encounter an unknown kanji and want to look it up without knowing how it is read. Draw the strokes in roughly the correct order and the system will offer matches."
  },
  {
    "q": "How do I type small kana like っ, ぁ, ぃ?",
    "a": "Small tsu (っ) is typed by doubling the following consonant — 'kk' gives っk, so typing 'kkа' produces っか. You can also type 'ltu' or 'xtu' to get っ directly. For other small kana, add 'l' or 'x' before the syllable: 'la' or 'xa' gives ぁ, 'li' or 'xi' gives ぃ, 'lyu' gives ゅ, and so on. These small versions appear frequently in combined sounds like きゃ (kya), しゅ (shu), and ちょ (cho)."
  },
  {
    "q": "Why does pressing 'n' sometimes give me ん and sometimes not?",
    "a": "The IME waits to see if you are typing a word that starts with 'n' (like 'na', 'ni', 'nu', 'ne', 'no'). If you want a standalone ん, type 'nn' (double n) to force it, or type 'n' followed by a non-n consonant. For example, 'kana' becomes かな (two characters), while 'kan' followed by a space or 'nn' produces かん. This is the single most common source of confusion for beginners, so getting the hang of 'nn' = ん early will save you a lot of frustration."
  }
];
const relatedTools = [
  {"name": "Hiragana Chart", "url": "/japanese/tools/hiragana-chart/"},
  {"name": "Katakana Chart", "url": "/japanese/tools/katakana-chart/"},
  {"name": "Kana Quiz", "url": "/japanese/tools/kana-quiz/"}
];
const headings = [
