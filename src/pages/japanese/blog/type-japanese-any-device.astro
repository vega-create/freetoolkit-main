<BlogLayout
  title="How to Type Japanese on Phone Computer and Tablet"
  description="Set up Japanese typing on iPhone, Android, Windows, and Mac. Step-by-step instructions plus a complete romaji-to-kana conversion table for beginners."
  language="japanese"
  category="study tips"
  tags={["beginner", "tools"]}
  publishDate="2026-03-03"
