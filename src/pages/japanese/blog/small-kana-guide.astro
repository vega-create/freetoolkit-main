          <th style="padding:10px 14px; text-align:left; border-bottom:2px solid #bae6fd;">Role</th>
          <th style="padding:10px 14px; text-align:left; border-bottom:2px solid #bae6fd;">Katakana Equivalent</th>
        </tr>
      </thead>
      <tbody>
        <tr style="background:#fff;">
          <td style="padding:9px 14px; font-size:1.4rem; text-align:center;">っ</td>
          <td style="padding:9px 14px;">Hiragana</td>
          <td style="padding:9px 14px;">Double consonant (geminate)</td>
          <td style="padding:9px 14px; font-size:1.3rem; text-align:center;">ッ</td>
        </tr>
        <tr style="background:#f0f9ff;">
          <td style="padding:9px 14px; font-size:1.4rem; text-align:center;">ゃ</td>
          <td style="padding:9px 14px;">Hiragana</td>
          <td style="padding:9px 14px;">Combination with -ya sound</td>
          <td style="padding:9px 14px; font-size:1.3rem; text-align:center;">ャ</td>
        </tr>
        <tr style="background:#fff;">
          <td style="padding:9px 14px; font-size:1.4rem; text-align:center;">ゅ</td>
          <td style="padding:9px 14px;">Hiragana</td>
          <td style="padding:9px 14px;">Combination with -yu sound</td>
          <td style="padding:9px 14px; font-size:1.3rem; text-align:center;">ュ</td>
        </tr>
