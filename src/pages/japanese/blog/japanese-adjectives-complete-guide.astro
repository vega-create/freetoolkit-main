<BlogLayout
  title="Japanese Adjectives: i-Adjectives vs na-Adjectives Complete Guide"
  description="Master i-adjectives and na-adjectives with complete conjugation tables, 50+ essential adjectives, tricky exceptions, and real sentence patterns."
  language="japanese"
  category="grammar"
  tags={["grammar", "vocabulary", "beginner", "adjectives"]}
  publishDate="2026-02-24"
  updatedDate="2026-03-19"
