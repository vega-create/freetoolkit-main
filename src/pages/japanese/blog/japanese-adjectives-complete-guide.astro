    <tr style="background:#f8fafc;"><td style="padding:8px; border:1px solid #e2e8f0;">Past</td><td style="padding:8px; border:1px solid #e2e8f0;">高<strong>かった</strong></td><td style="padding:8px; border:1px solid #e2e8f0;">静か<strong>だった</strong></td></tr>
    <tr><td style="padding:8px; border:1px solid #e2e8f0;">Te</td><td style="padding:8px; border:1px solid #e2e8f0;">高<strong>くて</strong></td><td style="padding:8px; border:1px solid #e2e8f0;">静か<strong>で</strong></td></tr>
    <tr style="background:#f8fafc;"><td style="padding:8px; border:1px solid #e2e8f0;">+ Noun</td><td style="padding:8px; border:1px solid #e2e8f0;">高<strong>い</strong>本</td><td style="padding:8px; border:1px solid #e2e8f0;">静か<strong>な</strong>部屋</td></tr>
  </tbody>
</table>

