    <tr style="background:#f8fafc;"><td style="padding:8px; border:1px solid #e2e8f0;">+ Noun</td><td style="padding:8px; border:1px solid #e2e8f0;">高<strong>い</strong>本</td><td style="padding:8px; border:1px solid #e2e8f0;">静か<strong>な</strong>部屋</td></tr>
