          <th style="padding:8px 10px;text-align:left">Row</th>
          <th style="padding:8px 10px;text-align:center">-a</th>
          <th style="padding:8px 10px;text-align:center">-i</th>
          <th style="padding:8px 10px;text-align:center">-u</th>
          <th style="padding:8px 10px;text-align:center">-e</th>
          <th style="padding:8px 10px;text-align:center">-o</th>
        </tr>
      </thead>
      <tbody>
        <tr style="background:#eff6ff"><td style="padding:7px 10px;font-weight:bold">Vowels</td><td style="padding:7px 10px;text-align:center;font-size:1.2rem">ア a</td><td style="padding:7px 10px;text-align:center;font-size:1.2rem">イ i</td><td style="padding:7px 10px;text-align:center;font-size:1.2rem">ウ u</td><td style="padding:7px 10px;text-align:center;font-size:1.2rem">エ e</td><td style="padding:7px 10px;text-align:center;font-size:1.2rem">オ o</td></tr>
        <tr style="background:#fff"><td style="padding:7px 10px;font-weight:bold">K</td><td style="padding:7px 10px;text-align:center;font-size:1.2rem">カ ka</td><td style="padding:7px 10px;text-align:center;font-size:1.2rem">キ ki</td><td style="padding:7px 10px;text-align:center;font-size:1.2rem">ク ku</td><td style="padding:7px 10px;text-align:center;font-size:1.2rem">ケ ke</td><td style="padding:7px 10px;text-align:center;font-size:1.2rem">コ ko</td></tr>
