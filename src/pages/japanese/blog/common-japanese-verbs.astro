        <tr style="background:#fff"><td style="padding:6px 12px">持つ もつ</td><td style="padding:6px 12px;text-align:center">G1</td><td style="padding:6px 12px">to hold/have</td><td style="padding:6px 12px">傘を持っています (I have an umbrella)</td></tr>
