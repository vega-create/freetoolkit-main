          <th style="padding:8px 12px;text-align:center">Group</th>
          <th style="padding:8px 12px;text-align:left">Meaning</th>
          <th style="padding:8px 12px;text-align:left">Polite Form</th>
        </tr>
      </thead>
      <tbody>
        <tr style="background:#fef2f2"><td style="padding:6px 12px;text-align:center">1</td><td style="padding:6px 12px">する</td><td style="padding:6px 12px;text-align:center">G3</td><td style="padding:6px 12px">to do</td><td style="padding:6px 12px">します</td></tr>
        <tr style="background:#fff"><td style="padding:6px 12px;text-align:center">2</td><td style="padding:6px 12px">ある</td><td style="padding:6px 12px;text-align:center">G1</td><td style="padding:6px 12px">to exist (things)</td><td style="padding:6px 12px">あります</td></tr>
        <tr style="background:#fef2f2"><td style="padding:6px 12px;text-align:center">3</td><td style="padding:6px 12px">いる</td><td style="padding:6px 12px;text-align:center">G2</td><td style="padding:6px 12px">to exist (living)</td><td style="padding:6px 12px">います</td></tr>
        <tr style="background:#fff"><td style="padding:6px 12px;text-align:center">4</td><td style="padding:6px 12px">行く (いく)</td><td style="padding:6px 12px;text-align:center">G1</td><td style="padding:6px 12px">to go</td><td style="padding:6px 12px">行きます</td></tr>
        <tr style="background:#fef2f2"><td style="padding:6px 12px;text-align:center">5</td><td style="padding:6px 12px">来る (くる)</td><td style="padding:6px 12px;text-align:center">G3</td><td style="padding:6px 12px">to come</td><td style="padding:6px 12px">来ます</td></tr>
        <tr style="background:#fff"><td style="padding:6px 12px;text-align:center">6</td><td style="padding:6px 12px">見る (みる)</td><td style="padding:6px 12px;text-align:center">G2</td><td style="padding:6px 12px">to see/watch</td><td style="padding:6px 12px">見ます</td></tr>
        <tr style="background:#fef2f2"><td style="padding:6px 12px;text-align:center">7</td><td style="padding:6px 12px">食べる (たべる)</td><td style="padding:6px 12px;text-align:center">G2</td><td style="padding:6px 12px">to eat</td><td style="padding:6px 12px">食べます</td></tr>
        <tr style="background:#fff"><td style="padding:6px 12px;text-align:center">8</td><td style="padding:6px 12px">飲む (のむ)</td><td style="padding:6px 12px;text-align:center">G1</td><td style="padding:6px 12px">to drink</td><td style="padding:6px 12px">飲みます</td></tr>
        <tr style="background:#fef2f2"><td style="padding:6px 12px;text-align:center">9</td><td style="padding:6px 12px">言う (いう)</td><td style="padding:6px 12px;text-align:center">G1</td><td style="padding:6px 12px">to say</td><td style="padding:6px 12px">言います</td></tr>
        <tr style="background:#fff"><td style="padding:6px 12px;text-align:center">10</td><td style="padding:6px 12px">思う (おもう)</td><td style="padding:6px 12px;text-align:center">G1</td><td style="padding:6px 12px">to think</td><td style="padding:6px 12px">思います</td></tr>
        <tr style="background:#fef2f2"><td style="padding:6px 12px;text-align:center">11</td><td style="padding:6px 12px">書く (かく)</td><td style="padding:6px 12px;text-align:center">G1</td><td style="padding:6px 12px">to write</td><td style="padding:6px 12px">書きます</td></tr>
        <tr style="background:#fff"><td style="padding:6px 12px;text-align:center">12</td><td style="padding:6px 12px">読む (よむ)</td><td style="padding:6px 12px;text-align:center">G1</td><td style="padding:6px 12px">to read</td><td style="padding:6px 12px">読みます</td></tr>
        <tr style="background:#fef2f2"><td style="padding:6px 12px;text-align:center">13</td><td style="padding:6px 12px">聞く (きく)</td><td style="padding:6px 12px;text-align:center">G1</td><td style="padding:6px 12px">to listen/ask</td><td style="padding:6px 12px">聞きます</td></tr>
