<BlogLayout
  title="Katakana Loanwords: 200+ English Words You Already Know in Japanese"
  description="Discover 200+ English loanwords in katakana and learn the pronunciation rules to decode new ones."
  language="japanese"
  category="kana"
  tags={["katakana", "vocabulary", "beginner"]}
  publishDate="2026-02-21"
