import BlogLayout from '../../../layouts/BlogLayout.astro';
const faq = [
  { q: `Is the Japanese zodiac the same as Chinese?`, a: `Very similar — both use the same 12 animals in the same order. The Japanese version (干支 eto) was adopted from China but has some cultural differences. The biggest difference is that Japan uses the wild boar (猪 inoshishi) instead of the pig used in Chinese zodiac.` },
  { q: `How do I find my zodiac animal?`, a: `Your birth year determines your animal. The cycle repeats every 12 years. For example, 2024 is the Year of the Dragon. Subtract or add 12 from any known year to find other years with the same animal.` },
  { q: `Is the zodiac still important in modern Japan?`, a: `Yes — each New Year prominently features the incoming zodiac animal on greeting cards (年賀状), decorations, and TV specials. Many Japanese people know their animal sign and associated personality traits. It is a common conversation topic.` },
  { q: `Does the zodiac affect personality like Western astrology?`, a: `Japanese zodiac personality traits are taken less seriously than Western horoscopes. Most people enjoy them as fun conversation starters rather than genuine personality assessments. However, some older people do consider zodiac compatibility for marriages.` },
  { q: `What vocabulary can I learn from the zodiac?`, a: `The zodiac teaches 12 animal kanji (鼠, 牛, 虎, etc.), counter words for animals, personality adjectives, and New Year vocabulary. It is an excellent cultural topic that naturally introduces useful vocabulary.` }
];
const relatedTools = [
  { name: "Kanji Lookup", url: "/japanese/tools/kanji-lookup/" },
  { name: "JLPT Vocabulary", url: "/japanese/tools/jlpt-vocabulary/" }
];
const headings = [
  { depth: 2, slug: "what-is-eto", text: "What Is Eto (干支)? The Japanese Zodiac System" },
  { depth: 2, slug: "twelve-animals", text: "The 12 Zodiac Animals — Kanji, Reading, and Years" },
  { depth: 2, slug: "personality-traits", text: "Personality Traits for Each Animal" },
  { depth: 2, slug: "new-year-traditions", text: "Zodiac and Japanese New Year Traditions" },
  { depth: 2, slug: "compatibility", text: "Animal Compatibility and Relationships" },
  { depth: 2, slug: "vs-chinese", text: "Japanese vs Chinese Zodiac — Key Differences" },
  { depth: 2, slug: "vocabulary", text: "Zodiac Vocabulary for Japanese Learners" },
  { depth: 2, slug: "modern-culture", text: "The Zodiac in Modern Japanese Culture" }
];
