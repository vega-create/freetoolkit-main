<BlogLayout
  title="How to Learn Hiragana: Complete Beginner Guide with Charts"
  description="Master all 46 hiragana characters in 2 weeks. Complete chart, mnemonic tips, 10-day learning plan, dakuten and combination sounds, free quiz and practice sheets."
  language="japanese"
  category="kana"
  tags={["hiragana", "beginner", "kana", "writing", "study-tips"]}
  publishDate="2026-02-19"
  image="https://images.pexels.com/photos/7526807/pexels-photo-7526807.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940"
