<BlogLayout
  title="Japanese Verb Conjugation: A Complete Practical Guide"
  description="Master Japanese verb conjugation with clear explanations of all 3 verb groups, polite form, negative, past tense, te-form, and potential form. Includes complete conjugation chart and practice resources."
  language="japanese"
  category="grammar"
  tags={["grammar", "verbs", "conjugation", "beginner", "intermediate"]}
  publishDate="2026-02-21"
  image="https://images.pexels.com/photos/7764194/pexels-photo-7764194.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940"
