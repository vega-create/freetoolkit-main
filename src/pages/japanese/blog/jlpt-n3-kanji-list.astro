import BlogLayout from '../../../layouts/BlogLayout.astro';
const faq = [
  { q: `How many kanji do I need for N3?`, a: `Approximately 350 new kanji beyond the 250 from N5 and N4, for a total of about 600 characters. You should recognize all of them and know their common readings and compound words.` },
  { q: `Should I learn on'yomi or kun'yomi first?`, a: `Learn both together in context. On'yomi (Chinese reading) appears in compound words like 学校 (がっこう), while kun'yomi (Japanese reading) is used when the kanji stands alone like 学ぶ (まなぶ). Learning words, not isolated readings, is the most effective approach.` },
  { q: `What is the best way to study N3 kanji?`, a: `Use radical decomposition to understand components, learn kanji in word pairs rather than isolation, use spaced repetition for review, and read extensively at your level. Writing practice also strengthens recognition.` },
  { q: `How long does it take to learn all N3 kanji?`, a: `At a pace of 5–10 new kanji per day with consistent review, you can cover the N3 kanji list in 2–3 months. However, truly knowing a kanji (all readings, common compounds, nuances) takes longer — plan for 4–6 months of solid study.` },
  { q: `Should I write kanji or just recognize them?`, a: `For the JLPT, recognition is sufficient — the test is multiple choice. However, writing practice significantly improves recognition and memory. Even writing each kanji 3–5 times when learning it helps.` }
];
