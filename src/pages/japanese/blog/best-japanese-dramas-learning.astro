---
import BlogLayout from '../../../layouts/BlogLayout.astro';
const faq = [
  { q: `Are dramas better than anime for learning Japanese?`, a: `For conversation skills, dramas are generally better because they use natural, everyday speech patterns. Anime often features exaggerated, archaic, or gender-specific language. Dramas model the way real Japanese people actually talk in daily life.` },
  { q: `Should I take notes while watching?`, a: `On first viewing, just enjoy the story. On second viewing, pause to note 5–10 new vocabulary words per episode. This two-pass method is more effective and enjoyable than constant pausing on your first watch.` },
  { q: `Where can I watch Japanese dramas with subtitles?`, a: `Netflix, Viki, and Crunchyroll have extensive Japanese drama libraries. NHK World offers free content. Viki is especially good because it often has both Japanese and English subtitles available simultaneously.` },
  { q: `How many episodes should I watch per week for learning?`, a: `Quality matters more than quantity. Actively studying 2–3 episodes per week (with vocabulary mining and shadowing) produces better results than passively watching 10 episodes. Follow the active watching method for maximum benefit.` },
  { q: `Can I learn Japanese from dramas alone?`, a: `Dramas are excellent for listening and vocabulary, but they cannot replace structured grammar study, kanji learning, or speaking practice. Use dramas as a supplement to — not a replacement for — a balanced study plan.` }
];
const relatedTools = [
  { name: "JLPT Vocabulary", url: "/japanese/tools/jlpt-vocabulary/" },
  { name: "Kana Converter", url: "/japanese/tools/romaji-to-kana/" },
  { name: "Kanji Lookup", url: "/japanese/tools/kanji-lookup/" }
];
const headings = [
  { depth: 2, slug: "why-dramas", text: "Why Japanese Dramas Are Perfect for Language Learning" },
  { depth: 2, slug: "beginner-dramas", text: "5 Dramas for Beginners (N5–N4)" },
  { depth: 2, slug: "intermediate-dramas", text: "5 Dramas for Intermediate Learners (N3–N2)" },
  { depth: 2, slug: "advanced-dramas", text: "5 Dramas for Advanced Learners (N2–N1)" },
  { depth: 2, slug: "active-watching", text: "The Active Watching Method — 5 Steps" },
  { depth: 2, slug: "subtitle-strategy", text: "Subtitle Strategy by Level" },
  { depth: 2, slug: "drama-vs-anime", text: "Drama vs Anime — Which Is Better for Learning?" },
  { depth: 2, slug: "weekly-routine", text: "Building a Drama-Based Study Routine" }
];
