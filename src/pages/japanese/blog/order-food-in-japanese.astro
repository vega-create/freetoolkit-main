---
import BlogLayout from '../../../layouts/BlogLayout.astro';
const faq = [
  {"q": "Do I need to tip in Japan?", "a": "No — tipping is not customary in Japan and can even be considered rude or confusing. Excellent service is simply the standard expectation at every restaurant, from convenience stores to high-end dining."},
  {"q": "How do I get the waiter's attention?", "a": "Say すみません (sumimasen) clearly and raise your hand slightly. Many restaurants also have a call button (呼び出しボタン) on the table — just press it and wait."},
  {"q": "What does おまかせ mean?", "a": "It means 'I leave it up to you' — the chef chooses your meal based on the freshest ingredients available. Common at sushi restaurants and high-end dining. Expect to pay a premium price."},
  {"q": "Can I ask for substitutions or modifications?", "a": "Japanese restaurants are less flexible about modifications than Western ones. For allergies, say アレルギーがあります (arerugii ga arimasu). Simple requests like no wasabi (わさび抜き) are usually fine."},
  {"q": "What if I cannot read the menu at all?", "a": "Many tourist-area restaurants have English menus or picture menus. You can ask メニューの英語版はありますか (eigo-ban wa arimasu ka) or simply point at food displays (食品サンプル) outside the restaurant."}
];
const relatedTools = [{"name": "JLPT Vocabulary", "url": "/japanese/tools/jlpt-vocabulary/"}, {"name": "Hiragana Chart", "url": "/japanese/tools/hiragana-chart/"}, {"name": "Katakana Chart", "url": "/japanese/tools/katakana-chart/"}];
