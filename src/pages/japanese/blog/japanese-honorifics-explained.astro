      <tr style="background:#f8fafc;"><td style="padding:8px; border:1px solid #e2e8f0;">先輩 (senpai)</td><td style="padding:8px; border:1px solid #e2e8f0;">Respectful</td><td style="padding:8px; border:1px solid #e2e8f0;">Senior classmates/colleagues</td><td style="padding:8px; border:1px solid #e2e8f0;">"Senior"</td></tr>
      <tr><td style="padding:8px; border:1px solid #e2e8f0;">くん (kun)</td><td style="padding:8px; border:1px solid #e2e8f0;">Casual</td><td style="padding:8px; border:1px solid #e2e8f0;">Boys, male colleagues</td><td style="padding:8px; border:1px solid #e2e8f0;">Casual "Mr."</td></tr>
