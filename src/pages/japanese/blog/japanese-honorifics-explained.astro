        <th style="padding:8px; border:1px solid #e2e8f0; text-align:left; background:#dbeafe;">Used For</th>
        <th style="padding:8px; border:1px solid #e2e8f0; text-align:left; background:#dbeafe;">English Equivalent</th>
      </tr>
    </thead>
    <tbody>
      <tr><td style="padding:8px; border:1px solid #e2e8f0;">様 (sama)</td><td style="padding:8px; border:1px solid #e2e8f0;">Very formal</td><td style="padding:8px; border:1px solid #e2e8f0;">Customers, deities, letters</td><td style="padding:8px; border:1px solid #e2e8f0;">"Esteemed Mr./Ms."</td></tr>
      <tr style="background:#f8fafc;"><td style="padding:8px; border:1px solid #e2e8f0;">さん (san)</td><td style="padding:8px; border:1px solid #e2e8f0;">Polite</td><td style="padding:8px; border:1px solid #e2e8f0;">Almost everyone</td><td style="padding:8px; border:1px solid #e2e8f0;">"Mr./Ms./Mrs."</td></tr>
